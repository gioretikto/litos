<schemalist>
  <schema path="/org/gtk/litos/" id="org.gtk.litos">
    <key name="transition" type="s">
      <choices>
        <choice value='none'/>
        <choice value='crossfade'/>
        <choice value='slide-left-right'/>
      </choices>
      <default>'none'</default>
      <summary>Transition</summary>
      <description>The transition to use when switching tabs.</description>
    </key>

    <key name="last-session-files" type="as">
      <default>[]</default>
      <summary>File aperti nell'ultima sessione</summary>
      <description>Elenco dei percorsi dei file da riaprire all'avvio.</description>
    </key>
  </schema>
</schemalist>
